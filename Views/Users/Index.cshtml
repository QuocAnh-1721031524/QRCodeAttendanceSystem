@model IEnumerable<QRCodeAttendanceSystem.Models.User>

@{
    ViewData["Title"] = "Danh sách người dùng";
}

<h2>Danh sách người dùng</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Tên đăng nhập</th>
            <th>Mã</th>
            <th>Email</th>
            <th>Vai trò</th>
            <th>Lớp</th>
            <th>Hoạt động</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Username</td>
                <td>@item.StudentCode</td>
                <td>@item.Email</td>
                <td>@item.Role?.RoleName</td>
                <td>@item.Class?.ClassName</td>
                <td>@item.IsActive</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>