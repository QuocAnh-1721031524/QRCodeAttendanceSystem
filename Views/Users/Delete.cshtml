@model QRCodeAttendanceSystem.Models.User

@{
    ViewData["Title"] = "Xóa người dùng";
}

<h2>Xóa người dùng</h2>

<h4>Bạn có chắc muốn xóa người dùng này không?</h4>

<div>
    <p><strong>Họ tên:</strong> @Model.FullName</p>
    <p><strong>Tên đăng nhập:</strong> @Model.Username</p>
    <p><strong>Email:</strong> @Model.Email</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="UserId" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>